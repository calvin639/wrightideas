# ─── Memories in Stone — Environment Variables ────────────────────────────────
# Copy to env.local.json for `make local-api`
# Production secrets go in AWS SSM Parameter Store (run `make setup-secrets`)

# ── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Runway ML ────────────────────────────────────────────────────────────────
# Get from https://app.runwayml.com/account/api-keys
RUNWAY_API_KEY=...

# ── AWS ──────────────────────────────────────────────────────────────────────
# These are auto-set by SAM during deployment
ORDERS_TABLE=memories-orders-dev
UPLOADS_BUCKET=memories-uploads-dev-123456789
VIDEOS_BUCKET=memories-videos-dev-123456789
VIDEO_GENERATION_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/...
MONTAGE_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/...

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
FRONTEND_URL=http://localhost:3000
SES_FROM_EMAIL=orders@memories.wrightideas.co
ADMIN_EMAIL=calvin.wright639@gmail.com
RUNWAY_WEBHOOK_URL=https://YOUR_API_GW_URL/dev/webhooks/runway
